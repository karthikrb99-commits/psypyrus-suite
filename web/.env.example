# PsyPyrus Web Companion App - Client Environment Configurations

# ─── Firebase Configuration ────────────────────────────────
# Replace these values with your project configurations from the Firebase Console
# (Project Settings → General → Your Apps)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id:web:your_app_hash
VITE_FIREBASE_FIRESTORE_DB_ID=(default)
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ─── PsyPyrus Sync Service ─────────────────────────────────
# URL of the sync-service backend (see sync-service/README.md)
# Local dev: http://localhost:3001
# Railway:   https://psypyrus-sync-service.up.railway.app
VITE_SYNC_API_URL=http://localhost:3001

# ─── AI / Gemini API ──────────────────────────────────────
# Gemini API key for SOAP note generation and diagnostic assistance
VITE_GEMINI_API_KEY=your_gemini_api_key

