# Environment Variables for PsyPyrus Sync Service
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── PostgreSQL (via Railway or Docker) ───────────────────
DATABASE_URL="postgresql://psypyrus:psypyrus_secret@localhost:5432/psypyrus_sync?schema=public"

# ─── Firebase Admin SDK ───────────────────────────────────
# Option 1: Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"

# Option 2: Inline service account (for Railway / CI environments)
# FIREBASE_PROJECT_ID="your-project-id"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://your-deployed-app.vercel.app"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
