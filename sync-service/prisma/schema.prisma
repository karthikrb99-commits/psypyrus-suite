// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Parity Schema — mirrors the client-side localStorage structure
// as defined in docs/05_backend_schema.md
// ─────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  firebaseUid     String        @unique @map("firebase_uid")
  email           String?       @unique
  phone           String?
  displayName     String?       @map("display_name")
  role            UserRole      @default(PATIENT)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  patients        Patient[]
  syncEvents      SyncEvent[]

  @@map("users")
}

enum UserRole {
  CLINICIAN
  PATIENT
  ADMIN
}

model Patient {
  id               Int            @id @default(autoincrement())
  firebaseOwnerId  String         @map("firebase_owner_id")
  name             String
  age              Int?
  gender           String?
  email            String?
  phone            String?
  riskStatus       String?        @default("None") @map("risk_status")
  specialty        String?
  abhaNumber       String?        @map("abha_number")
  abhaAddress      String?        @map("abha_address")
  registrationDate DateTime       @default(now()) @map("registration_date")
  lastModified     DateTime       @default(now()) @updatedAt @map("last_modified")
  createdAt        DateTime       @default(now()) @map("created_at")

  owner            User           @relation(fields: [firebaseOwnerId], references: [firebaseUid])
  appointments     Appointment[]
  clinicalNotes    ClinicalNote[]
  assessments      Assessment[]
  moodLogs         MoodLog[]
  homeworkTasks    HomeworkTask[]
  medications      Medication[]

  @@map("patients")
}

model Appointment {
  id           Int       @id @default(autoincrement())
  patientId    Int       @map("patient_id")
  patientName  String    @map("patient_name")
  dateTime     String    @map("date_time")
  status       String    @default("Scheduled")
  notes        String?
  fee          Float?
  isVideo      Boolean   @default(false) @map("is_video")
  code         String?
  lastModified DateTime  @default(now()) @updatedAt @map("last_modified")
  createdAt    DateTime  @default(now()) @map("created_at")

  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model ClinicalNote {
  id              Int      @id @default(autoincrement())
  patientId       Int      @map("patient_id")
  title           String
  noteType        String   @default("GENERAL") @map("note_type")
  bodyJson        String   @map("body_json")
  isRiskAlert     Boolean  @default(false) @map("is_risk_alert")
  riskDisclaimer  String?  @map("risk_disclaimer")
  timestamp       DateTime @default(now())
  lastModified    DateTime @default(now()) @updatedAt @map("last_modified")

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("clinical_notes")
}

model Assessment {
  id           Int      @id @default(autoincrement())
  patientId    Int      @map("patient_id")
  type         String
  score        Int
  details      String?
  answersJson  String?  @map("answers_json")
  date         DateTime @default(now())
  lastModified DateTime @default(now()) @updatedAt @map("last_modified")

  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model MoodLog {
  id               Int      @id @default(autoincrement())
  patientId        Int      @map("patient_id")
  moodScore        Int      @map("mood_score")
  moodNote         String?  @map("mood_note")
  gratitude        String?
  breathingSeconds Int      @default(0) @map("breathing_seconds")
  date             DateTime @default(now())
  lastModified     DateTime @default(now()) @updatedAt @map("last_modified")

  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("mood_logs")
}

model HomeworkTask {
  id           Int      @id @default(autoincrement())
  patientId    Int      @map("patient_id")
  description  String
  isCompleted  Boolean  @default(false) @map("is_completed")
  assignedDate DateTime @default(now()) @map("assigned_date")
  lastModified DateTime @default(now()) @updatedAt @map("last_modified")

  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("homework_tasks")
}

model Medication {
  id            Int      @id @default(autoincrement())
  patientId     Int      @map("patient_id")
  name          String
  dosage        String?
  frequency     String?
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  prescribedBy  String?  @map("prescribed_by")
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  lastModified  DateTime @default(now()) @updatedAt @map("last_modified")
  createdAt     DateTime @default(now()) @map("created_at")

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medications")
}

model SecurityAuditLog {
  id                  Int      @id @default(autoincrement())
  action              String
  details             String?
  actor               String?
  ipAddress           String?  @map("ip_address")
  encryptionStandard  String?  @default("AES-GCM-256") @map("encryption_standard")
  timestamp           DateTime @default(now())

  @@map("security_audit_logs")
}

model GamificationProfile {
  id                Int      @id @default(autoincrement())
  firebaseUid       String   @unique @map("firebase_uid")
  userRole          String   @default("Patient") @map("user_role")
  xp                Int      @default(0)
  level             Int      @default(1)
  mindCoins         Int      @default(0) @map("mind_coins")
  unlockedSkinsJson String   @default("[]") @map("unlocked_skins_json")
  lastModified      DateTime @default(now()) @updatedAt @map("last_modified")

  @@map("gamification_profiles")
}

// Tracks every sync event for audit and conflict resolution
model SyncEvent {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  clientDevice   String?  @map("client_device")
  syncTimestamp  DateTime @default(now()) @map("sync_timestamp")
  deltasJson     String   @map("deltas_json")
  conflictsJson  String   @default("{}") @map("conflicts_json")
  status         String   @default("APPLIED")

  user           User     @relation(fields: [userId], references: [firebaseUid])

  @@map("sync_events")
}
